{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the NexGenShop application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "createdAt", "updatedAt"]
    },
    "CartItem": {
      "title": "CartItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productVariantId": { "type": "string" },
        "quantity": { "type": "number" },
        "priceAtAddToCart": { "type": "number" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles and serves as the root for user data."
        }
      },
      {
        "path": "/users/{userId}/cart/cart/items/{itemId}",
        "definition": {
          "entityName": "CartItem",
          "schema": { "$ref": "#/backend/entities/CartItem" },
          "description": "Individual items in a user's shopping bag."
        }
      },
      {
        "path": "/users/{userId}/wishlist/wishlist/items/{itemId}",
        "definition": {
          "entityName": "WishlistItem",
          "schema": { "$ref": "#/backend/entities/WishlistItem" },
          "description": "Individual items saved to a user's wishlist."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "description": "Public product catalog."
        }
      }
    ]
  }
}