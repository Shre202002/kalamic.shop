rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXGENSHOP SECURITY RULES
     * 
     * Core Philosophy:
     * Security is enforced through path-based authorization where data is nested under user IDs.
     * This ruleset matches the application implementation using /users/ path root.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Unified user data rules. Covers /users/{userId} and all subcollections
     * like cart, wishlist, and orders.
     */
    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId) || isAdmin();

      match /{allSubpaths=**} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Fallback for any legacy userProfiles paths.
     */
    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId) || isAdmin();

      match /{allSubpaths=**} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Product categories. Publicly readable; admin-only writes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Product catalog and nested reviews/variants.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /{allSubpaths=**} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }

      // Specific override for reviews to allow owners to manage their own
      match /reviews/{reviewId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if (resource != null && resource.data.userId == request.auth.uid) || isAdmin();
      }
    }

    /**
     * @description Discount coupon codes.
     */
    match /couponCodes/{couponCodeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Admin role registry. 
     * Users can read to check their own status; write is forbidden for clients.
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}